{
  "rows": "section[data-testid='card-section']",
  "columns": [
    {
      "name": "title",
      "selector": "button[aria-label]",
      "attribute": "aria-label"
    },
    {
      "name": "url",
      "selector": "a[href*='/gp/video/detail/'], a[href*='/dp/']",
      "attribute": "href"
    },
    {
      "name": "thumbnail",
      "selector": "img[data-testid='base-image'], [data-testid='base-image']",
      "attribute": "src"
    },
    {
      "name": "purchase_type",
      "selector": "[data-testid='badge-label'], span[class*='badge'], span[class*='Badge']"
    }
  ]
}
