          "path": "thumbnail.thumbnails.0.url"
        },
        {
          "name": "channel",
          "path": "ownerText.runs.0.text"
        },
        {
          "name": "channel_url",
          "path": "ownerText.runs.0.navigationEndpoint.browseEndpoint.canonicalBaseUrl"
        },
        {
          "name": "views_and_date",
          "path": "shortViewCountText.simpleText"
        },
        {
          "name": "duration",
          "path": "lengthText.simpleText"
        }
      ]
    }
  ]
}
