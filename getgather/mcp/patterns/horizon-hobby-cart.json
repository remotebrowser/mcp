{
  "rows": "div[data-test*='cart-product-line-item']",
  "columns": [
    {
      "name": "alert",
      "selector": "div.alert__root"
    },
    {
      "name": "product_image_url",
      "selector": "img[data-test='product-image']",
      "attribute": "src"
    },
    {
      "name": "product_name",
      "selector": "div > a[title] > p"
    },
    {
      "name": "product_url",
      "selector": "div > a[title]",
      "attribute": "href"
    },
    {
      "name": "product_price",
      "selector": "div[data-test='product-price'] span"
    },
    {
      "name": "product_price_original",
      "selector": "div[data-test='product-price'] span:nth-of-type(2)"
    }
  ]
}