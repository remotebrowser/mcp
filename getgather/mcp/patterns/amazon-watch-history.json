{
  "rows": "div[data-testid='activity-history-item']",
  "columns": [
    {
      "name": "title",
      "selector": "a[href*='/gp/video/detail']:not(:has(img))"
    },
    {
      "name": "url",
      "selector": "a[href*='/gp/video/detail/'], a[href*='/video/detail/'], a[href*='/dp/']",
      "attribute": "href"
    },
    {
      "name": "thumbnail",
      "selector": "a[href*='/gp/video/detail/'] img, img[class*='thumbnail'], img[class*='poster'], img",
      "attribute": "src"
    },
    {
      "name": "watched_date",
      "selector": "li[data-automation-id^='wh-date-'] > div > h3"
    }
  ]
}
