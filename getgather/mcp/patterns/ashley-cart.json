{
  "rows": "div.cart-row",
  "columns": [
    {
      "name": "product_name",
      "selector": "div.cart-product-block a"
    },
    {
      "name": "product_url",
      "selector": "div.cart-product-block a",
      "attribute": "href"
    },
    {
      "name": "product_image",
      "selector": "div.item-image-desktop img",
      "attribute": "src"
    },
    {
      "name": "product_sku",
      "selector": "span.skuId"
    },
    {
      "name": "product_attribute",
      "selector": "div.attribute"
    },
    {
      "name": "product_price",
      "selector": "div.line-item-total"
    }
  ]
}