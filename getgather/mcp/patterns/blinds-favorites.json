{
  "rows": "div[class*='FavoritesPresentation__ProductDiv']",
  "columns": [
    {
      "name": "url",
      "selector": "article > a",
      "attribute": "href"
    },
    {
      "name": "image",
      "selector": "article > a > img",
      "attribute": "src"
    },
    {
      "name": "name",
      "selector": "article > div:nth-of-type(1) > h2[data-test-id='favoriteproductname'] > a"
    },
    {
      "name": "price",
      "selector": "article > div:nth-of-type(1) > div:nth-of-type(2) > div:nth-of-type(1)"
    },
    {
      "name": "size",
      "selector": "article > div:nth-of-type(1) > div:nth-of-type(2) > div:nth-of-type(2)"
    }
  ]
}
