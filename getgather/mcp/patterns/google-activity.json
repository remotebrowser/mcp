{
  "rows": "div[role='listitem']",
  "columns": [
    {
      "name": "image",
      "selector": "div img",
      "attribute": "src"
    },
    {
      "name": "source",
      "selector": "div > div > div > span"
    },
    {
      "name": "activity",
      "selector": "div > div:nth-of-type(2) > div > div"
    },
    {
      "name": "url",
      "selector": "div > div:nth-of-type(2) > div > div > a",
      "attribute": "href"
    },
    {
      "name": "date",
      "selector": "div > div:nth-of-type(2) > div > div:nth-of-type(2) > div"
    }
  ]
}
