{
  "rows": "[data-indexcard]",
  "columns": [
    {
      "name": "title",
      "selector": "[data-testid=card-headline]"
    },
    {
      "name": "url",
      "selector": "[data-testid=internal-link]",
      "attribute": "href"
    },
    {
      "name": "summary",
      "selector": "[data-testid=anchor-inner-wrapper] + div"
    },
    {
      "name": "image",
      "selector": "img",
      "attribute": "src"
    }
  ]
}