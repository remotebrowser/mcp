{
  "rows": "yt-lockup-view-model, ytm-shorts-lockup-view-model-v2",
  "columns": [
    {
      "name": "title",
      "selector": "h3 a span"
    },
    {
      "name": "url",
      "selector": "h3 a",
      "attribute": "href"
    },
    {
      "name": "thumbnail",
      "selector": "yt-thumbnail-view-model img",
      "attribute": "src"
    },
    {
      "name": "channel",
      "selector": "yt-content-metadata-view-model .ytContentMetadataViewModelMetadataRow:first-child span.ytContentMetadataViewModelMetadataText:first-child, yt-content-metadata-view-model .yt-content-metadata-view-model__metadata-row:first-child span:first-child"
    },
    {
      "name": "channel_url",
      "selector": "yt-content-metadata-view-model a[href^='/@']",
      "attribute": "href"
    },
    {
      "name": "views_and_date",
      "selector": "yt-content-metadata-view-model .ytContentMetadataViewModelDelimiter + span, yt-content-metadata-view-model .yt-content-metadata-view-model__delimiter + span, .shortsLockupViewModelHostOutsideMetadataSubhead span"
    },
    {
      "name": "duration",
      "selector": "badge-shape .yt-badge-shape__text"
    }
  ]
}
